# IA Palomar — Variables de entorno
# Copiá este archivo como .env y completá con tus valores

# Supabase (opcional — la app funciona sin estas variables en modo mock)
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key-aqui

# API de IA (opcional — para activar respuestas reales en lugar del mock)
VITE_OPENAI_API_KEY=sk-...
VITE_ANTHROPIC_API_KEY=sk-ant-...

# Configuración de la app
VITE_APP_NAME=IA Palomar
VITE_APP_VERSION=1.0.0
